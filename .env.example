# Copy to .env and fill in. .env is gitignored.

# SASL credentials for the upstream Redpanda Cloud cluster.
# The proxy passes these through unchanged.
RPK_USER=
RPK_PASS=
RPK_SASL_MECHANISM=SCRAM-SHA-256

# Where the test script connects to the proxy.
# Local plaintext POC: 127.0.0.1
# Remote TLS deployment: the public hostname (e.g., kroxy.example.com)
PROXY_HOST=127.0.0.1
